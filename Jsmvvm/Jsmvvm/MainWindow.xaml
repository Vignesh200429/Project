<Window x:Class="Jsmvvm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Jsmvvm"
        xmlns:converter ="clr-namespace:Jsmvvm.ValueConverter"
        xmlns:vm="clr-namespace:Jsmvvm.ViewModel;assembly=Jsmvvm.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="800" Background="Beige">
    <Window.Resources >
        <vm:UserViewModel x:Key="userviewmodel" ></vm:UserViewModel>
        <converter:YestoBoolValueConverter x:Key="YestoBoolConverter" ></converter:YestoBoolValueConverter>
        <converter:NotoBoolValueConverter x:Key="NotoBoolConverter" ></converter:NotoBoolValueConverter>
    </Window.Resources>
    <Window.DataContext >
        <Binding Source="{StaticResource userviewmodel}"></Binding>
    </Window.DataContext>
    <StackPanel >
        <StackPanel  >
        <Label Content="Enter Your Name" FontSize="20" FontWeight="Bold" ></Label>
            <TextBox Height="30" FontSize="15" Text="{Binding UserModelData.Name}" ></TextBox>
        <Label Content="Enter Your Age" FontSize="20" FontWeight="Bold"></Label>
            <TextBox Height="30" FontSize="15" Text="{Binding UserModelData.Age}"></TextBox>
        <Label Content="Enter Your Qualification" FontSize="20" FontWeight="Bold" ></Label>
            <TextBox Height="30" FontSize="15" Text="{Binding UserModelData.Qualification}"></TextBox>
        <Label Content="Mark" FontSize="20" FontWeight="Bold"></Label>
            <TextBox Height="30" FontSize="15" Text="{Binding UserModelData.Mark}"></TextBox>
            <Label Content="Experence" FontSize="20" FontWeight="Bold"></Label>
            <RadioButton Content="Yes" IsChecked="{Binding UserModelData.Experence , Converter={StaticResource YestoBoolConverter }}" ></RadioButton>
            <RadioButton Content="No" IsChecked="{Binding UserModelData.Experence , Converter={StaticResource NotoBoolConverter }}" ></RadioButton>
        </StackPanel>
        <ListBox ItemsSource="{Binding UserList,Mode=OneWay}" Height="150" Width="420" FontSize="20" FontWeight="DemiBold">
            <ListBox.ItemTemplate >
                <DataTemplate >
                    <StackPanel >
                        <TextBlock Text="{Binding Name,Mode=OneWay}" ></TextBlock>
                        <TextBlock Text="{Binding Age,Mode=OneWay}" ></TextBlock>
                        <TextBlock Text="{Binding Qualification,Mode=OneWay}" ></TextBlock>
                        <TextBlock Text="{Binding Mark,Mode=OneWay}" ></TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Content="Submit" Command="{Binding RegisterCommend}" Height="40" Width="120" Background="Pink" FontSize="15" FontWeight="Bold" Margin="10"></Button>
        <Button Content="Clear" Command="{Binding ClearCommend}" Height="40" Width="120" Background="Pink" FontSize="15" FontWeight="Bold" Margin="10"></Button>
    </StackPanel>
</Window>
