<Window x:Class="sqlquery.Home"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sqlquery"
        mc:Ignorable="d"
        Title="Home" Height="450" Width="800">
    <DockPanel >
        <TextBlock Text="BILLING SYSTEM - HOME" DockPanel.Dock="Top" Background="Blue" Foreground="White" ></TextBlock>
        <StackPanel DockPanel.Dock="Left" Background="Azure" Orientation="Vertical" HorizontalAlignment="Left">
            <Button Content="New Bill" Background="LightPink" x:Name="btnnewbill" Click="btnnewbill_Click" ></Button>
            <Button Content="View Bills" Background="LightPink" x:Name="btnviewbills"></Button>
            <Button Content="Customers" Background="LightPink" x:Name="btncustomers"></Button>
            <Button Content="Products" Background="LightPink" x:Name="btnproducts"></Button>
            <Button Content="Reports" Background="LightPink" x:Name="btnreports" ></Button>
        </StackPanel>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"></Frame>

        <Grid Background="White">
            <StackPanel Margin="20">
                <TextBlock Text="Dashboard Summary" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    
                    <Border Background="LightBlue" Width="150" Height="120" Margin="0,0,10,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Bills Today" FontWeight="Bold" />
                            <TextBlock Text="12" FontSize="24" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    
                    <Border Background="LightGreen" Width="170" Height="120"  Padding="10">
                        <StackPanel>
                            <TextBlock Text="Total Amount" FontWeight="Bold" />
                            <TextBlock Text="$1,450" FontSize="24" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    
    </DockPanel> 
</Window>
