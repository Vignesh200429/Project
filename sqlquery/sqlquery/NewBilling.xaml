<Window x:Class="sqlquery.NewBilling"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sqlquery"
        mc:Ignorable="d"
        Title="NewBilling" Height="550" Width="800">

    
        <StackPanel >
            <TextBlock Text="New Supermarket Bill"  ></TextBlock>
            <StackPanel Orientation="Horizontal"  >
                <TextBlock Text="Products" ></TextBlock>
                <ComboBox x:Name="cmbproducts" Height="40" Width=" 220" Margin="10,10,0,0" SelectionChanged="cmbproducts_SelectionChanged"></ComboBox>
                <TextBlock Text="Unit:" ></TextBlock>
                <TextBox x:Name="txtunit" Width="100" Height="40" Padding="5" ></TextBox>
                <TextBlock Text="Price:" ></TextBlock>
                <TextBox x:Name="txtprice" Width="100" Height="40" Padding="5" ></TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Quantity" ></TextBlock>
                <TextBox x:Name="txtquantity" Height=" 40" Width="50" Background="Wheat" Text="1" Padding="5"></TextBox>
                <Button x:Name="btnaddtobill" Content="Add To Bill" Click="btnaddtobill_Click" Background="LightGoldenrodYellow" Foreground="Black" Margin="20,0,0,0"  ></Button>
            </StackPanel>
            <DataGrid Height="200" x:Name="dggrid" AutoGenerateColumns="False" >
                <DataGrid.Columns >
                    <DataGridTextColumn Header="Product" Binding="{Binding Product}" Width="2*" ></DataGridTextColumn>
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="*"></DataGridTextColumn>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="UnitPrice" Binding="{Binding UnitPrice}" Width="*"></DataGridTextColumn>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*"></DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        <StackPanel Orientation="Horizontal" >
            <TextBlock Text="Total:" HorizontalAlignment="Center"  Margin=" 0,0,0,0" ></TextBlock>
            <TextBox x:Name="txttotal" Height="40" Width=" 150" ></TextBox>
        </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,50,0,0" >
                <Button Content="Print" x:Name="btnprint" ></Button>
                <Button Content="Cancel" x:Name="btncancle" ></Button>
            </StackPanel>
        </StackPanel>
    



</Window>
