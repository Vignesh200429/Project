<Window x:Class="sqlquery.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sqlquery"
        mc:Ignorable="d"
        Title="Login" Height="850" Width="800">
    <Grid>
        <TabControl >
            <TabItem Header="Register">
                <StackPanel >
                    <TextBlock Text="User Name"  ></TextBlock>
                    <TextBox x:Name="txtusername" ></TextBox>
                    <TextBlock Text="Password" ></TextBlock>
                    <PasswordBox x:Name="pwpassword"></PasswordBox>
                    <TextBlock Text="Email"></TextBlock>
                    <TextBox x:Name="txtemail"></TextBox>
                    <TextBlock Text="Phone Number"></TextBlock>
                    <TextBox x:Name="txtphone"></TextBox>
                    <TextBlock Text="Country" ></TextBlock>
                    <ComboBox x:Name="cmbcountry" SelectionChanged="cmbcountry_SelectionChanged"></ComboBox>
                    <TextBlock Text="State" ></TextBlock>
                    <ComboBox x:Name="cmbstate" SelectionChanged="cmbstate_SelectionChanged"></ComboBox>
                    <TextBlock Text="City" ></TextBlock>
                    <ComboBox x:Name="cmbcity" ></ComboBox>
                    <Button Content="Register" x:Name="btnreg" Click="btnreg_Click" ></Button>
                </StackPanel>
            </TabItem>
            <TabItem Header="Login" >
                <StackPanel >
                    <TextBlock Text="User Name" ></TextBlock>
                    <TextBox x:Name="txtLoginusername"></TextBox>
                    <TextBlock Text="Password" ></TextBlock>
                    <PasswordBox x:Name="pwLoginpassword"></PasswordBox>
                    <Button Content="Login" x:Name="btnlog" Click="btnlog_Click"></Button>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>

</Window>
