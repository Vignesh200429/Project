<Window x:Class="TokenSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TokenSystem"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="400" Background="Plum" WindowStyle="None" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
                                      <!-- Over All Border -->
    <Border Height="410" Width="360" CornerRadius="20" Background=" #fff"  >
        <Border.Effect >
            <DropShadowEffect ShadowDepth="20" Opacity=".3" BlurRadius="20" ></DropShadowEffect>
        </Border.Effect>
                                      <!-- Creating Grid for Rows and Columns -->
        <Grid>
            <Grid.ColumnDefinitions >
                <ColumnDefinition ></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions >
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto" ></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto" ></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
            </Grid.RowDefinitions>
                                     <!-- Title for this project -->
            <TextBlock Text="Token System" Grid.Row="0" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold" Margin="20" ></TextBlock>
            
                                     <!-- Entry Level -->
            <TextBlock Text="Enter Name Here:" Grid.Row="1" HorizontalAlignment="Center" FontSize="20" FontWeight="Light" Margin="0,0,0,5" ></TextBlock>
            <TextBox x:Name="txtname" Grid.Row="2" HorizontalAlignment="Center" Height="40" Width="220" FontSize="20"  BorderThickness="2" Margin="0,0,0,0" >
                <TextBox.Resources >
                    <Style TargetType="Border"  >
                        <Setter Property="CornerRadius" Value="20" ></Setter>
                        <Setter Property="BorderBrush" Value="Black" ></Setter>
                        <Setter Property="BorderThickness" Value="5" ></Setter>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            
                                    <!-- Access Button for our Usage-->
            <Button Content="Save" x:Name="btnsave" Grid.Row="3" Background="Green" Click="btnsave_Click"></Button>
            <Button Content="Call" x:Name="btncall" Grid.Row="4" Background="Orange" Click="btncall_Click"></Button>
            <Button Content="Clear" x:Name="btnclear" Grid.Row="5" Background="Red" Click="btnclear_Click"></Button>
        </Grid>
        
    </Border>
</Window>
